---
import ImageCard from '../ui/ImageCard.astro';
import type { SupportedLanguage } from '../../i18n/config';
import { getHomepageSection } from '../../lib/sanity-fetchers';
import { urlFor } from '../../lib/sanity';

export interface Props {
  className?: string;
  lang?: SupportedLanguage;
}

const {
  className = '',
  lang = 'en' as SupportedLanguage
} = Astro.props;

const methodologyData = await getHomepageSection('methodology', lang);

const methodologyCards = methodologyData?.cards || [];
const sectionTitle = methodologyData?.title || 'Our Methodology';
const footerText = methodologyData?.footerText;
---

<section class={`section-padding bg-cream-white ${className}`} aria-labelledby="methodology-heading">
  <div class="container">
    <div class="max-w-6xl mx-auto">
      <h2 id="methodology-heading" class="text-3xl font-bold text-florize-green mb-6 text-center">
        {sectionTitle}
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8">
        {methodologyCards.map((card) => (
          <ImageCard
            image={card.image ? urlFor(card.image).width(400).height(200).url() : ''}
            imageAlt={card.imageAlt || card.title}
            title={card.title}
            description={card.description}
          />
        ))}
      </div>

      {footerText && (
        <p class="text-center mt-8 text-lg text-gray-700 max-w-4xl mx-auto">
          {footerText}
        </p>
      )}
    </div>
  </div>
</section>
