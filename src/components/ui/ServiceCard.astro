---
import type { SanityService } from '../../types/sanity';
import Card from './Card.astro';
import RatingStars from './RatingStars.astro';
import Badge from './Badge.astro';
import Button from './Button.astro';
import SanityImage from './SanityImage.astro';
import { t } from '../../i18n/translations';

export interface Props {
  service: SanityService;
}

const { service } = Astro.props;
const lang = service.language as 'en' | 'de';
---

<Card className="flex flex-col h-full overflow-hidden p-0">
  {service.base.heroImage && (
    <div class="service-card-image">
      <SanityImage
        image={service.base.heroImage}
        alt={`${service.base.name} flowers`}
        width={400}
        height={200}
        loading="lazy"
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
        class="w-full h-full object-cover"
      />
      {service.base.winnerBadge && (
        <div class="badge-overlay">
          <Badge text={service.base.winnerBadge} variant="winner" size="sm" />
        </div>
      )}
    </div>
  )}

  <div class="p-6 flex flex-col grow">
    <div class="flex items-start justify-between mb-4">
      <h2 class="text-2xl font-bold text-florize-green">
        {service.base.name}
      </h2>
      {!service.base.heroImage && service.base.winnerBadge && (
        <Badge text={service.base.winnerBadge} variant="winner" size="sm" />
      )}
    </div>

    <div class="flex items-center gap-2 mb-4">
      <RatingStars rating={service.base.rating} size="md" />
      <span class="font-bold text-gray-800">{service.base.rating}/5</span>
    </div>

    <p class="text-gray-700 mb-4 grow">
      {service.base.description}
    </p>

    <div class="mb-4">
      <div class="text-sm text-gray-600 mb-1">{t(lang, 'table.priceRange')}</div>
      <div class="font-semibold text-florize-green">{service.base.priceRange}</div>
    </div>

    <div class="flex flex-col gap-2">
      {service.affiliate?.url && (
        <Button
          href={service.affiliate.url}
          variant="primary"
          size="md"
          text={`${t(lang, 'buttons.visitService')} →`}
          className="w-full text-center"
          target="_blank"
          rel="noopener noreferrer"
        />
      )}
      <Button
        href={`/${lang}/services/${service.base.id}`}
        variant={service.affiliate?.url ? "secondary" : "primary"}
        size="md"
        text={t(lang, 'buttons.readReview')}
        className="w-full text-center"
      />
    </div>
  </div>
</Card>

<style>
  .service-card-image {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .service-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .service-card-image:hover img {
    transform: scale(1.05);
  }

  .badge-overlay {
    position: absolute;
    top: 12px;
    right: 12px;
  }
</style>
