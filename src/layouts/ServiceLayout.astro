---
// Service Layout following FindFerries pattern with centralized data preparation
// Includes all original features: tabs, TOC, sticky elements, and sections

import type { SanityService } from '../types/sanity';
import BaseLayout from './BaseLayout.astro';
import BreadcrumbNavigation from '../components/navigation/BreadcrumbNavigation.astro';
import PortableTextRenderer from '../components/PortableTextRenderer.astro';
import ServiceHero from '../components/sections/ServiceHero.astro';
import QuickSummary from '../components/sections/QuickSummary.astro';
import ServiceOverview from '../components/sections/ServiceOverview.astro';
import ProsConsGrid from '../components/sections/ProsConsGrid.astro';
import ComparisonSection from '../components/sections/ComparisonSection.astro';
import FinalRecommendation from '../components/sections/FinalRecommendation.astro';
import RelatedReviews from '../components/sections/RelatedReviews.astro';
import AffiliateBannerSection from '../components/sections/AffiliateBannerSection.astro';
import StickyCTA from '../components/ui/StickyCTA.astro';
import ReviewByline from '../components/ui/ReviewByline.astro';
import AccordionFAQ from '../components/ui/AccordionFAQ.astro';
import BestForCards from '../components/ui/BestForCards.astro';
import PromoCode from '../components/ui/PromoCode.astro';
import VSComparison from '../components/ui/VSComparison.astro';
import StickyTOC from '../components/ui/StickyTOC.astro';
import ReadingProgress from '../components/ui/ReadingProgress.astro';
import TestingMetrics from '../components/ui/TestingMetrics.astro';
import TabSection from '../components/ui/TabSection.astro';
import { getAffiliateLink } from '../utils/affiliateLinks';
import { generateServiceSchema } from '../utils/seo';
import { urlFor } from '../lib/sanity';
import { t } from '../i18n/translations';

interface TOCItem {
  id: string;
  text: string;
  level: number;
}

export interface Props {
  service: SanityService;
}

const { service } = Astro.props;

// Get language from service data
const lang = service.language as 'en' | 'de';

// Get affiliate link from Sanity (with fallback)
const affiliateUrl = await getAffiliateLink(service.base.id, lang);

// Breadcrumb items
const breadcrumbItems = [
  { label: t(lang, 'layout.home'), href: `/${lang}` },
  { label: t(lang, 'layout.services'), href: `/${lang}/services` },
  { label: `${service.base.name} ${t(lang, 'layout.review')}` },
];

// Generate structured data for SEO
const serviceSchema = generateServiceSchema({
  ...service,
  affiliate_url: affiliateUrl
});

// Generate Table of Contents based on available sections (matches original exactly)
const tocItems: TOCItem[] = [];

// Service Overview
if (service.overview?.positioning && service.overview?.content) {
  tocItems.push({
    id: 'overview',
    text: t(lang, 'layout.serviceOverview'),
    level: 2
  });
}

// Best For Scenarios
if (service.components?.bestForScenarios && service.components.bestForScenarios.length > 0) {
  tocItems.push({
    id: 'perfect-for',
    text: t(lang, 'layout.perfectFor'),
    level: 2
  });
}

// Testing Metrics
if (service.components?.testingMetrics && service.components.testingMetrics.length > 0) {
  tocItems.push({
    id: 'testing-metrics',
    text: t(lang, 'layout.testingResults'),
    level: 2
  });
}

// Tab Sections - always present
tocItems.push({
  id: 'tab-review',
  text: `📖 ${t(lang, 'layout.completeReview')}`,
  level: 2
});

tocItems.push({
  id: 'tab-quick-ref',
  text: `⚡ ${t(lang, 'layout.quickReference')}`,
  level: 2
});

tocItems.push({
  id: 'tab-comparisons',
  text: `⚖️ ${t(lang, 'layout.howItCompares')}`,
  level: 2
});

tocItems.push({
  id: 'tab-faqs',
  text: `💡 ${t(lang, 'layout.faqsMore')}`,
  level: 2
});
---

<BaseLayout
  title={service.base.title}
  description={service.base.description}
  keywords={service.seo?.keywords}
  showBreadcrumbs={true}
  structuredData={serviceSchema}
>
  <!-- Reading Progress Bar -->
  <ReadingProgress />

  <BreadcrumbNavigation slot="breadcrumbs" items={breadcrumbItems} />

  <!-- Hero Section -->
  <ServiceHero
    title={`${service.base.name} ${t(lang, 'layout.review')} 2026: ${service.base.winnerBadge || t(lang, 'layout.expertAnalysis')}`}
    subtitle={service.base.description}
    rating={service.base.rating}
    badge={service.base.winnerBadge}
    backgroundImage={service.base.heroImage ? urlFor(service.base.heroImage).width(1600).url() : undefined}
  />

  <article>
    <div class="container">
      <!-- Quick Summary -->
      <QuickSummary
        bestFor={service.summary?.bestFor || t(lang, 'layout.qualityDelivery')}
        priceRange={service.base.priceRange}
        delivery={service.summary?.delivery || service.base.deliveryOptions.join(', ')}
        rating={service.summary?.ratingText || `${service.base.rating}/5`}
        serviceName={service.base.name}
        affiliateUrl={affiliateUrl}
        lang={lang}
      />

      <!-- Review Byline -->
      <ReviewByline
        datePublished={service.seo?.datePublished}
        dateModified={service.seo?.dateModified}
        expertTested={true}
      />

      <!-- Promo Code (if exists) -->
      {service.affiliate?.promoCode && (
        <PromoCode
          code={service.affiliate.promoCode.code}
          description={service.affiliate.promoCode.description}
          expiryDate={service.affiliate.promoCode.expiryDate}
          serviceName={service.base.name}
          affiliateUrl={affiliateUrl}
        />
      )}

      <!-- Service Overview (if structured data exists) -->
      {service.overview?.positioning && service.overview?.content && (
        <section id="overview">
          <ServiceOverview
            serviceName={service.base.name}
            positioning={service.overview.positioning}
            content={service.overview.content}
          />
        </section>
      )}

      <!-- Best For Scenarios (if exists) -->
      {service.components?.bestForScenarios && service.components.bestForScenarios.length > 0 && (
        <section class="content-section" id="perfect-for">
          <BestForCards
            scenarios={service.components.bestForScenarios}
            title={t(lang, 'layout.perfectFor')}
          />
        </section>
      )}

      <!-- Testing Metrics Dashboard (if data exists) - Prominently displayed -->
      {service.components?.testingMetrics && service.components.testingMetrics.length > 0 && (
        <section class="content-section" id="testing-metrics">
          <TestingMetrics
            metrics={service.components.testingMetrics}
            title={t(lang, 'layout.testingResults')}
          />
        </section>
      )}

      <!-- Tabbed Content Sections -->
      <section class="content-section" id="tabbed-content">
        <TabSection tabs={[
          { id: 'review', label: t(lang, 'layout.completeReview'), icon: '📖' },
          { id: 'quick-ref', label: t(lang, 'layout.quickReference'), icon: '⚡' },
          { id: 'comparisons', label: t(lang, 'layout.howItCompares'), icon: '⚖️' },
          { id: 'faqs', label: t(lang, 'layout.faqsMore'), icon: '💡' }
        ]}>
          <!-- Tab 1: Complete Review -->
          <div class="tab-panel active" role="tabpanel" data-tab-panel="review" id="tab-review">
            <article class="tab-content-wrapper">
              <div class="prose-content">
                {service.body && <PortableTextRenderer value={service.body} />}
              </div>
            </article>
          </div>

          <!-- Tab 2: Quick Reference -->
          <div class="tab-panel" role="tabpanel" data-tab-panel="quick-ref" id="tab-quick-ref">
            <div class="tab-content-wrapper">
              {/* Pros & Cons */}
              {service.components?.pros && service.components?.cons && (
                <ProsConsGrid
                  serviceName={service.base.name}
                  prosTitle={service.components.prosTitle || t(lang, 'layout.strengths')}
                  consTitle={service.components.consTitle || t(lang, 'layout.considerations')}
                  pros={service.components.pros}
                  cons={service.components.cons}
                />
              )}

              {!service.components?.pros && !service.components?.cons && (
                <p class="empty-tab-message">{t(lang, 'layout.prosConsComingSoon')}</p>
              )}
            </div>
          </div>

          <!-- Tab 3: How It Compares -->
          <div class="tab-panel" role="tabpanel" data-tab-panel="comparisons" id="tab-comparisons">
            <div class="tab-content-wrapper">
              {/* Feature Comparison */}
              {service.components?.featureComparison && (
                <div class="comparison-section">
                  <VSComparison
                    service1Name={service.base.name}
                    service2Name={service.components.featureComparison.competitorName}
                    features={service.components.featureComparison.features.map(f => ({
                      feature: f.feature,
                      service1: f.serviceValue,
                      service2: f.competitorValue
                    }))}
                    winner={service.components.featureComparison.winner === 'service' ? 1 : service.components.featureComparison.winner === 'competitor' ? 2 : undefined}
                  />
                </div>
              )}

              {/* Competitive Comparison */}
              {service.comparisons?.items && service.comparisons.items.length > 0 && (
                <div class="comparison-section">
                  <ComparisonSection
                    serviceName={service.base.name}
                    comparisons={service.comparisons.items}
                    useCases={service.comparisons.useCases}
                  />
                </div>
              )}

              {!service.components?.featureComparison && (!service.comparisons?.items || service.comparisons.items.length === 0) && (
                <p class="empty-tab-message">{t(lang, 'layout.comparisonComingSoon')}</p>
              )}
            </div>
          </div>

          <!-- Tab 4: FAQs & More -->
          <div class="tab-panel" role="tabpanel" data-tab-panel="faqs" id="tab-faqs">
            <div class="tab-content-wrapper">
              {/* FAQs */}
              {service.components?.faqs && service.components.faqs.length > 0 && (
                <div class="faqs-wrapper">
                  <AccordionFAQ items={service.components.faqs} />
                </div>
              )}

              {/* Final Recommendation */}
              {service.recommendations?.sections && service.recommendations.sections.length > 0 && (
                <div class="recommendation-wrapper">
                  <FinalRecommendation
                    serviceName={service.base.name}
                    rating={service.base.rating}
                    ratingLabel={service.base.winnerBadge || 'Expert Tested'}
                    sections={service.recommendations.sections}
                    affiliateUrl={affiliateUrl}
                    ctaText={service.recommendations.cta || `Visit ${service.base.name}`}
                  />
                </div>
              )}

              {/* Related Reviews */}
              {service.related?.reviews && service.related.reviews.length > 0 && (
                <div class="related-wrapper">
                  <RelatedReviews
                    heading={service.related.heading || t(lang, 'layout.compareOtherServices')}
                    reviews={service.related.reviews}
                  />
                </div>
              )}

              {!service.components?.faqs && !service.recommendations?.sections && !service.related?.reviews && (
                <p class="empty-tab-message">{t(lang, 'layout.additionalInfoComingSoon')}</p>
              )}
            </div>
          </div>
        </TabSection>
      </section>

      <!-- Affiliate Banner Section -->
      <div class="max-w-4xl mx-auto">
        <AffiliateBannerSection
          serviceId={service.base.id}
          serviceName={service.base.name}
          affiliateUrl={affiliateUrl}
          lang={lang}
        />
      </div>
    </div>
  </article>

  <!-- Sticky CTA Bar -->
  <StickyCTA
    serviceName={service.base.name}
    affiliateUrl={affiliateUrl}
    rating={service.base.rating}
    lang={lang}
  />

  <!-- Sticky Table of Contents -->
  {tocItems.length > 0 && (
    <StickyTOC items={tocItems} lang={lang} />
  )}
</BaseLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .content-section {
    margin: 3rem 0;
  }

  /* Tab panel visibility - critical for tab switching */
  .tab-panel {
    display: none;
    animation: fadeIn 0.3s ease-in;
  }

  .tab-panel.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tab-content-wrapper {
    padding: 2rem 0;
  }

  .prose-content {
    max-width: 65ch;
    margin: 0 auto;
  }

  .prose-content :global(h2) {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--florize-green, #4a7c59);
    margin: 2rem 0 1rem 0;
  }

  .prose-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
    color: #1f2937;
    margin: 1.5rem 0 0.75rem 0;
  }

  .prose-content :global(p) {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #374151;
    margin: 0 0 1.25rem 0;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin: 0 0 1.25rem 0;
    padding-left: 1.5rem;
  }

  .prose-content :global(li) {
    margin: 0 0 0.5rem 0;
  }

  .prose-content :global(strong) {
    font-weight: 700;
    color: #1f2937;
  }

  .prose-content :global(a) {
    color: var(--florize-green, #4a7c59);
    text-decoration: underline;
  }

  .prose-content :global(a:hover) {
    color: #6fa581;
  }

  .empty-tab-message {
    text-align: center;
    color: #6b7280;
    padding: 3rem 1rem;
    font-size: 1.125rem;
  }

  .comparison-section {
    margin: 2rem 0;
  }

  .faqs-wrapper,
  .recommendation-wrapper,
  .related-wrapper {
    margin: 2rem 0;
  }

  .faqs-wrapper + .recommendation-wrapper,
  .recommendation-wrapper + .related-wrapper {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 2px solid #e5e7eb;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 0.75rem;
    }

    .content-section {
      margin: 2rem 0;
    }

    .tab-content-wrapper {
      padding: 1rem 0;
    }

    .prose-content {
      max-width: 100%;
    }

    .prose-content :global(h2) {
      font-size: 1.5rem;
    }

    .prose-content :global(h3) {
      font-size: 1.25rem;
    }

    .prose-content :global(p) {
      font-size: 1rem;
    }
  }
</style>