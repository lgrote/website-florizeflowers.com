---
// Service page using the FindFerries-pattern layout with centralized data preparation
import { getServices } from '../../../lib/sanity-fetchers';
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { SUPPORTED_LANGUAGES } from '../../../i18n/config';

export async function getStaticPaths() {
  // Generate paths for each language
  return (await Promise.all(SUPPORTED_LANGUAGES.map(async (lang) => {
    const services = await getServices(lang);
    return services.map((service) => ({
      params: { lang, service: service.base.id },
      props: { service },
    }));
  }))).flat();
}

const { service } = Astro.props;
---

<ServiceLayout service={service} />
