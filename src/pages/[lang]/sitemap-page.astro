---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUPPORTED_LANGUAGES, type SupportedLanguage } from '../../i18n/config';
import { getPageBySlug, getServices, getOccasions } from '../../lib/sanity-fetchers';

export async function getStaticPaths() {
  return SUPPORTED_LANGUAGES.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: SupportedLanguage };

// Get page content from Sanity
const pageData = await getPageBySlug('sitemap', lang);

const services = await getServices(lang);
const occasions = await getOccasions(lang);

const sortedServices = [...services].sort((a, b) => b.base.rating - a.base.rating);
const sortedOccasions = [...occasions].sort((a, b) => a.base.name.localeCompare(b.base.name));
---

<BaseLayout
  title={pageData?.title || 'Sitemap'}
  description={pageData?.description || ''}
>
  <div class="py-12">
    <div class="container">
      <h1 class="text-4xl md:text-5xl font-bold text-florize-green mb-8 text-center">
        {pageData?.intro?.heading || 'Sitemap'}
      </h1>
      <p class="text-center text-lg text-gray-700 mb-12 max-w-3xl mx-auto">
        {pageData?.intro?.paragraph || ''}
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <!-- Main Pages -->
        <div class="bg-white p-6 rounded-lg shadow-md">
          <h2 class="text-2xl font-bold text-florize-green mb-4">{pageData?.sections?.main || 'Main Pages'}</h2>
          <ul class="space-y-2">
            <li><a href={`/${lang}`} class="text-florize-green hover:underline">Home</a></li>
            <li><a href={`/${lang}/services`} class="text-florize-green hover:underline">All Service Reviews</a></li>
            <li><a href={`/${lang}/occasions`} class="text-florize-green hover:underline">All Occasion Guides</a></li>
            <li><a href={`/${lang}/guides`} class="text-florize-green hover:underline">Buying Guides</a></li>
            <li><a href={`/${lang}/about`} class="text-florize-green hover:underline">About Us</a></li>
            <li><a href={`/${lang}/contact`} class="text-florize-green hover:underline">Contact</a></li>
          </ul>
        </div>

        <!-- Service Reviews -->
        <div class="bg-white p-6 rounded-lg shadow-md">
          <h2 class="text-2xl font-bold text-florize-green mb-4">{pageData?.sections?.services || 'Services'}</h2>
          <ul class="space-y-2">
            {sortedServices.map((service) => (
              <li>
                <a href={`/${lang}/services/${service.base.id}`} class="text-florize-green hover:underline">
                  {service.base.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Occasion Guides -->
        <div class="bg-white p-6 rounded-lg shadow-md">
          <h2 class="text-2xl font-bold text-florize-green mb-4">{pageData?.sections?.occasions || 'Occasions'}</h2>
          <ul class="space-y-2">
            {sortedOccasions.map((occasion) => (
              <li>
                <a href={`/${lang}/occasions/${occasion.base.id}`} class="text-florize-green hover:underline">
                  {occasion.base.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal & Info -->
        <div class="bg-white p-6 rounded-lg shadow-md">
          <h2 class="text-2xl font-bold text-florize-green mb-4">{pageData?.sections?.legal || 'Legal'}</h2>
          <ul class="space-y-2">
            <li><a href={`/${lang}/privacy-policy`} class="text-florize-green hover:underline">Privacy Policy</a></li>
            <li><a href={`/${lang}/terms-of-use`} class="text-florize-green hover:underline">Terms of Use</a></li>
            <li><a href={`/${lang}/affiliate-disclosure`} class="text-florize-green hover:underline">Affiliate Disclosure</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-600">
          {pageData?.labels?.cantFind || "Can't find what you're looking for?"} <a href={`/${lang}/contact`} class="text-florize-green hover:underline font-semibold">{pageData?.labels?.contactHelp || 'Contact us'}</a> for help.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
