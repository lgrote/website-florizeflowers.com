---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PortableTextRenderer from '../../components/PortableTextRenderer.astro';
import { SUPPORTED_LANGUAGES, type SupportedLanguage } from '../../i18n/config';
import { getPageBySlug } from '../../lib/sanity-fetchers';

export async function getStaticPaths() {
  return SUPPORTED_LANGUAGES.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: SupportedLanguage };

const termsPage = await getPageBySlug('terms-of-use', lang);

if (!termsPage) {
  throw new Error(`Terms of use page content not found for language: ${lang}`);
}
---

<BaseLayout
  title={termsPage.title}
  description={termsPage.description}
>
  <div class="py-12">
    <div class="container">
      <div class="max-w-3xl mx-auto prose prose-lg">
        <PortableTextRenderer value={termsPage.body} />
      </div>
    </div>
  </div>
</BaseLayout>
