---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PortableTextRenderer from '../../components/PortableTextRenderer.astro';
import { SUPPORTED_LANGUAGES, type SupportedLanguage } from '../../i18n/config';
import { getPageBySlug } from '../../lib/sanity-fetchers';

export async function getStaticPaths() {
  return SUPPORTED_LANGUAGES.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: SupportedLanguage };

const affiliatePage = await getPageBySlug('affiliate-disclosure', lang);

if (!affiliatePage) {
  throw new Error(`Affiliate disclosure page content not found for language: ${lang}`);
}
---

<BaseLayout
  title={affiliatePage.title}
  description={affiliatePage.description}
>
  <div class="py-12">
    <div class="container">
      <div class="max-w-3xl mx-auto prose prose-lg">
        <PortableTextRenderer value={affiliatePage.body} />
      </div>
    </div>
  </div>
</BaseLayout>
