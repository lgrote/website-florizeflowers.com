---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNavigation from '../../components/navigation/BreadcrumbNavigation.astro';
import PortableTextRenderer from '../../components/PortableTextRenderer.astro';
import { SUPPORTED_LANGUAGES, type SupportedLanguage } from '../../i18n/config';
import { t } from '../../i18n/translations';
import { getPageBySlug } from '../../lib/sanity-fetchers';

export async function getStaticPaths() {
  return SUPPORTED_LANGUAGES.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: SupportedLanguage };

const contactPage = await getPageBySlug('contact', lang);

if (!contactPage) {
  throw new Error(`Contact page content not found for language: ${lang}`);
}

// Breadcrumb items
const breadcrumbItems = [
  { label: t(lang, 'nav.home'), href: `/${lang}` },
  { label: t(lang, 'nav.contact') },
];
---

<BaseLayout
  title={contactPage.title}
  description={contactPage.description}
  showBreadcrumbs={true}
>
  <BreadcrumbNavigation slot="breadcrumbs" items={breadcrumbItems} />
  <div class="py-12">
    <div class="container">
      <div class="max-w-2xl mx-auto prose prose-lg">
        <PortableTextRenderer value={contactPage.body} />
      </div>
    </div>
  </div>
</BaseLayout>
