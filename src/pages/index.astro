---
/**
 * Root redirect page - detects user's language and redirects to appropriate locale
 * This page redirects immediately to /en/ or /de/ based on browser language
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import { DEFAULT_LANGUAGE } from "../i18n/config";

export const prerender = true;
---

<BaseLayout
    title="Florize Flowers - Redirecting..."
    description="Redirecting to your language."
    lang={DEFAULT_LANGUAGE}
>
    <div class="flex items-center justify-center min-h-[60vh]">
        <div class="text-center p-8">
            <p class="text-gray-500 text-lg">Redirecting to your language...</p>
            <p class="text-gray-400 text-sm mt-6">
                If you are not redirected automatically,
                <a href="/en/" class="text-pink-600 underline">click here for English</a>
                or <a href="/de/" class="text-pink-600 underline">hier für Deutsch</a>.
            </p>
        </div>
    </div>
</BaseLayout>

<script>
    const lang = (navigator.language || "en").toLowerCase().startsWith("de") ? "de" : "en";
    location.replace(`/${lang}/${location.search}${location.hash}`);
</script>
